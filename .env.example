# Novera Personal Access Token (opk_…) — used by the MCP server, CI, and any
# headless CLI usage. Create one in the webapp: Settings → Developer → API keys.
NOVERA_API_KEY=

# Optional: target a non-production environment.
# NOVERA_ENV=local            # production | development | local

# Optional overrides (mostly for local backend development):
# NOVERA_API_BASE=http://localhost:18088/api/v1
# NOVERA_WEBAPP_BASE=http://localhost:18531
# NOVERA_CLIENT_ID=sub_cli_novera

# Optional: OpenAPI source for `pnpm gen:types`.
# NOVERA_OPENAPI_URL=https://api.dev.novera.ink/openapi.json
